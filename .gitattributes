# Default: normalize to LF in repo, checkout as-is (let OS decide)
* text=auto

# Windows scripts: always CRLF on checkout
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Shell scripts: always LF on checkout
*.sh    text eol=lf

# Dockerfiles and config: LF
Dockerfile*     text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.json          text eol=lf
*.env*          text eol=lf

# Docs: auto
*.md    text eol=lf
