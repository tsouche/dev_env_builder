################################################################################
# SET Backend Development Environment - v0.7.0
# Base: tsouche/base_rust_dev:latest (v0.7.0+)
# 
# The base image already provides:
# - Ubuntu 22.04 LTS
# - Rust stable toolchain (via rustup)
# - Build tools (gcc, cmake, pkg-config, libssl-dev)
# - MongoDB Shell (mongosh)
# - GitHub CLI (gh)
# - Bun runtime (for QMD support)
# - Playwright + Chromium (for gstack /browse skill)
# - QMD (Query Markup Documents) pre-installed globally
# - QMD aliases (qmd-update, qmd-refresh, qmd-status, qmd-search, qmd-reindex)
# - QMD auto-init function in .bashrc (checks ~/.cache/qmd/index.sqlite)
# - Claude Code MCP configuration (~/.claude/settings.json)
# - SSH server configured with host keys
# - VS Code extensions auto-install
# - User rustdev (UID 1026, GID 110)
# - /workspace directory
# - Shell aliases (ll, la, grep colors, cargo shortcuts)
# - Git aliases (st, co, br, ci, lg)
# - Development service functions (dev-h, dev-v, dev-s, dev-c, dev-l)
# - Directory structure: ~/.local/share, ~/.cache/qmd (proper permissions)
################################################################################
FROM tsouche/base_rust_dev:latest

# Git configuration arguments from .env
ARG GIT_USER_NAME
ARG GIT_USER_EMAIL

# Override with local user's SSH public key
# This allows each machine/user to have their own SSH access
USER root
COPY authorized_keys /home/rustdev/.ssh/authorized_keys
RUN chown 1026:110 /home/rustdev/.ssh/authorized_keys && \
    chmod 600 /home/rustdev/.ssh/authorized_keys

# Configure git with user credentials (override base image if needed)
USER rustdev
RUN if [ -n "${GIT_USER_NAME}" ] && [ -n "${GIT_USER_EMAIL}" ]; then \
        git config --global user.name "${GIT_USER_NAME}" && \
        git config --global user.email "${GIT_USER_EMAIL}"; \
    fi

################################################################################
# AI Agentic Tools - Claude Code
################################################################################
USER root
# Installation du CLI Claude Code (toujours latest au build)
RUN npm install -g @anthropic-ai/claude-code@latest

# S'assurer que les permissions du home sont correctes pour la config .claude
RUN chown -R 1026:110 /home/rustdev

USER rustdev

# Note: Development aliases, shell shortcuts, and git aliases are now
# included in the base image (tsouche/rust_dev_container:latest)
# No need to redefine them here.

################################################################################
# QMD - Query Markup Documents (AI-optimized code indexing)
# NOTE: QMD, MCP config, and aliases are in the base image.
#       This section only handles deployment-specific files.
################################################################################

# Copy QMD initialization script (deployment-specific)
USER root
COPY init_qmd.sh /home/rustdev/init_qmd.sh
RUN chmod +x /home/rustdev/init_qmd.sh && \
    chown 1026:110 /home/rustdev/init_qmd.sh

# Copy global CLAUDE.md template to .claude directory (deployment-specific)
COPY CLAUDE.md.template /home/rustdev/.claude/CLAUDE.md
RUN chown 1026:110 /home/rustdev/.claude/CLAUDE.md

################################################################################
# gstack - Claude Code Skills Framework
# NOTE: gstack is installed at runtime into the persistent ~/.claude volume
#       via init_gstack.sh (not baked into the image).
#       This section only copies the initialization script.
################################################################################

# Copy gstack initialization script (deployment-specific)
USER root
COPY init_gstack.sh /home/rustdev/init_gstack.sh
RUN chmod +x /home/rustdev/init_gstack.sh && \
    chown 1026:110 /home/rustdev/init_gstack.sh

USER root
WORKDIR /workspace

CMD ["/usr/sbin/sshd", "-D"]
